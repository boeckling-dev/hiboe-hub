# Clerk Authentication
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk Redirect URLs (no changes needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Neon PostgreSQL
# Get from: https://console.neon.tech → Your Project → Connection String
# Important: must end with ?sslmode=require
DATABASE_URL=

# Anthropic Claude API (used from Phase 2 onwards)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Brave Search API (for resolving real recipe URLs)
# Get from: https://api.search.brave.com/ → API Keys (free tier: 2000 queries/month)
BRAVE_SEARCH_API_KEY=

# Vercel Blob Storage (used from Phase 4 onwards)
# Get from: https://vercel.com → Storage → Blob → Token
BLOB_READ_WRITE_TOKEN=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
